{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/prompt-hub-frontend/browser",
  "installCommand": "npm install",
  "routes": [
    {
      "src": "/(.+\\..+)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
